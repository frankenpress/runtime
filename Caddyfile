# FrankenPress runtime Caddyfile.
#
# Env vars (with defaults — override at container start):
#   REDIS_URL                redis backing store for Souin (default: redis:6379)
#   FP_CACHE_TTL             cache entry TTL                  (default: 5m)
#   FP_CACHE_STALE           stale-while-revalidate window    (default: 1h)
#   FP_CACHE_DEFAULT_CONTROL upstream Cache-Control fallback  (default: public, s-maxage=300)
#   FP_CACHE_BYPASS_EXTRA    extra path-prefix alternation appended to the
#                            cache-bypass regex below           (default: empty)
#                            — set to e.g. `|^/api/private/|^/members/`
#                              (note the leading `|`) to add custom paths
#                              that must NEVER be cached
#   FP_DOCROOT               WordPress webroot                (default: /app/web)
#   FP_PORT                  public HTTP listen port          (default: 8080)
#   FP_METRICS_PORT          Prometheus metrics listen port   (default: 9145)
#
# Cacheability model:
#   Souin only caches anonymous public GETs. Two layers of bypass:
#     1. Path bypass — anything that's auth-aware or admin-only at the URL
#        level (wp-admin, wp-login, wp-cron, wp-json, xmlrpc) is excluded
#        via the cache block's `regex.exclude`. Bedrock layout (`/wp/...`)
#        and classic layout (`/...`) are both covered.
#     2. Cookie bypass — any request carrying a WP auth or per-user state
#        cookie (`wordpress_logged_in_*`, `wp-postpass_*`, `comment_author_*`)
#        skips the cache directive entirely. This is what stops a logged-in
#        admin's response from being cached and served to the next visitor.
#
#   Anything else — anonymous GETs to non-auth public paths — is cached
#   per the standard HTTP semantics (upstream `Cache-Control` honoured;
#   `default_cache_control` is the fallback when the upstream is silent).
#
# Invalidation:
#   The fp-mu-plugin's SouinInvalidator deletes cache entries directly in Redis
#   using the documented key format (GET-<scheme>-<host>-<path>, IDX_<...>,
#   SURROGATE_<tag>). Souin's HTTP invalidation APIs (PURGE / POST-CRUD /
#   /api.souin admin) are unreliable in cache-handler v0.16.0 — see PHASE-0.md.
{
	admin localhost:2019
	auto_https off
	metrics

	# Trust upstream proxies in private CIDR ranges (k8s pod-to-pod, in-cluster
	# LB / ingress, sidecars). When enabled, Caddy honours `X-Forwarded-Proto`
	# from those sources, so the request's scheme reflects what the *client*
	# saw — not what reached the pod over plain HTTP.
	#
	# Why this matters: Souin's cache key shape is `GET-<scheme>-<host>-<path>`.
	# Without trusted_proxies, cluster-internal traffic to Caddy is `http://`,
	# so Souin caches under `http`. Meanwhile WordPress (which sets
	# `$_SERVER['HTTPS']='on'` from the same header in `application.php`) emits
	# canonical `https://` URLs. The fp-mu-plugin SouinInvalidator computes
	# DEL keys from those https URLs — which never match the http-keyed
	# cache, so post saves never invalidate the rendered page.
	#
	# fp-mu-plugin v0.2.1+ DELs both schemes defensively, but trusting the
	# proxy is the correct fix and removes the divergence at the source.
	servers {
		trusted_proxies static private_ranges
		client_ip_headers X-Forwarded-For
	}

	cache {
		# GET/HEAD only. Adding POST/PUT/etc. causes cache-handler to cache
		# write responses themselves rather than invalidating GETs (verified
		# behaviour in v0.16.0). Invalidation goes through direct Redis DEL
		# from the fp-mu-plugin.
		allowed_http_verbs GET HEAD

		ttl {$FP_CACHE_TTL:5m}
		stale {$FP_CACHE_STALE:1h}
		mode bypass

		redis {
			url {$REDIS_URL:redis:6379}
		}

		cdn {
			strategy hard
		}

		# Path-level bypass. Anything matching is never stored, never
		# served from cache. The default set covers every auth-aware /
		# admin-only path on a stock WordPress install in either layout
		# (Bedrock `/wp/...` or classic `/...`). FP_CACHE_BYPASS_EXTRA
		# is appended verbatim — set it to `|^/api/private/` style
		# alternations to add custom paths.
		regex {
			exclude (?i)^(/wp)?/(wp-admin/|wp-login\.php|wp-cron\.php|xmlrpc\.php|wp-json/){$FP_CACHE_BYPASS_EXTRA:}
		}

		# Upstream may override per-response with Cache-Control headers.
		default_cache_control "{$FP_CACHE_DEFAULT_CONTROL:public, s-maxage=300}"
	}
}

:{$FP_PORT:8080} {
	root * {$FP_DOCROOT:/app/web}

	encode zstd br gzip

	# /healthz — cheap liveness probe target (no PHP, no cache).
	@healthz path /healthz

	# .php whitelist: only WordPress entry points may execute PHP. Defends
	# against malicious uploads landing in the docroot. WP entry-point list
	# is conservative; extend per-site if a plugin needs additional ones
	# (e.g. wp-comments-post.php, xmlrpc.php for legacy clients).
	@bad_php {
		path *.php
		not path /index.php /wp-login.php /wp-cron.php /wp-admin/*.php /wp/index.php /wp/wp-login.php /wp/wp-cron.php /wp/wp-admin/*.php
	}

	# Mutually-exclusive handle blocks — first match wins, regardless of
	# Caddy's directive auto-ordering.
	handle @healthz {
		respond "ok" 200
	}

	handle @bad_php {
		respond 404
	}

	# Cookie-based cache bypass. The path-based bypass in the global cache
	# block above catches admin/login/cron/REST URLs. This catches anything
	# else where the request itself signals "this user expects fresh /
	# personalised content":
	#   wordpress_logged_in_*  any logged-in user (admin or not)
	#   wp-postpass_*          visitor unlocked a password-protected post
	#   comment_author_*       visitor recently posted a comment and is
	#                          expected to see it before moderation
	# Matching requests skip the `cache` directive entirely — straight to
	# PHP, never stored. Anonymous traffic (no matching cookie) flows
	# through the cached `handle` block below.
	@auth_or_state_cookie header_regexp Cookie (wordpress_logged_in_|wp-postpass_|comment_author_)
	handle @auth_or_state_cookie {
		try_files {path} {path}/ /index.php?{query}
		php_server
	}

	handle {
		cache
		try_files {path} {path}/ /index.php?{query}
		php_server
	}
}

# Prometheus metrics on a dedicated port so scrapers don't traverse cache or PHP.
:{$FP_METRICS_PORT:9145} {
	metrics /metrics
}
