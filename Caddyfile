# FrankenPress runtime Caddyfile.
#
# Env vars (with defaults — override at container start):
#   REDIS_URL                redis backing store for Souin (default: redis:6379)
#   FP_CACHE_TTL             cache entry TTL                  (default: 5m)
#   FP_CACHE_STALE           stale-while-revalidate window    (default: 1h)
#   FP_CACHE_DEFAULT_CONTROL upstream Cache-Control fallback  (default: public, s-maxage=300)
#   FP_DOCROOT               WordPress webroot                (default: /app/web)
#   FP_PORT                  public HTTP listen port          (default: 8080)
#   FP_METRICS_PORT          Prometheus metrics listen port   (default: 9145)
#
# Invalidation:
#   The fp-mu-plugin's SouinInvalidator deletes cache entries directly in Redis
#   using the documented key format (GET-<scheme>-<host>-<path>, IDX_<...>,
#   SURROGATE_<tag>). Souin's HTTP invalidation APIs (PURGE / POST-CRUD /
#   /api.souin admin) are unreliable in cache-handler v0.16.0 — see PHASE-0.md.

{
	admin localhost:2019
	auto_https off
	metrics

	cache {
		# GET/HEAD only. Adding POST/PUT/etc. causes cache-handler to cache
		# write responses themselves rather than invalidating GETs (verified
		# behaviour in v0.16.0). Invalidation goes through direct Redis DEL
		# from the fp-mu-plugin.
		allowed_http_verbs GET HEAD

		ttl {$FP_CACHE_TTL:5m}
		stale {$FP_CACHE_STALE:1h}
		mode bypass

		redis {
			url {$REDIS_URL:redis:6379}
		}

		cdn {
			strategy hard
		}

		# Upstream may override per-response with Cache-Control headers.
		default_cache_control "{$FP_CACHE_DEFAULT_CONTROL:public, s-maxage=300}"
	}
}

:{$FP_PORT:8080} {
	root * {$FP_DOCROOT:/app/web}

	encode zstd br gzip

	# /healthz — cheap liveness probe target (no PHP, no cache).
	@healthz path /healthz

	# .php whitelist: only WordPress entry points may execute PHP. Defends
	# against malicious uploads landing in the docroot. WP entry-point list
	# is conservative; extend per-site if a plugin needs additional ones
	# (e.g. wp-comments-post.php, xmlrpc.php for legacy clients).
	@bad_php {
		path *.php
		not path /index.php /wp-login.php /wp-cron.php /wp-admin/*.php /wp/index.php /wp/wp-login.php /wp/wp-cron.php /wp/wp-admin/*.php
	}

	# Mutually-exclusive handle blocks — first match wins, regardless of
	# Caddy's directive auto-ordering.
	handle @healthz {
		respond "ok" 200
	}

	handle @bad_php {
		respond 404
	}

	handle {
		cache
		try_files {path} {path}/ /index.php?{query}
		php_server
	}
}

# Prometheus metrics on a dedicated port so scrapers don't traverse cache or PHP.
:{$FP_METRICS_PORT:9145} {
	metrics /metrics
}
